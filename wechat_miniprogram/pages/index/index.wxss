/* pages/index/index.wxss */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 状态栏 */
.status-bar {
  display: flex;
  justify-content: center;
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.status-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.status-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 10rpx;
}

/* 对话区域 */
.chat-area {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.message {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
}

.message-user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.message-avatar image {
  width: 100%;
  height: 100%;
}

.message-content {
  max-width: 70%;
  margin: 0 20rpx;
}

.message-user .message-content {
  align-items: flex-end;
}

.message-text {
  padding: 20rpx 30rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.message-user .message-text {
  background-color: #ff6b9d;
  color: #fff;
}

.message-ai .message-text {
  background-color: #fff;
  color: #333;
}

.message-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 思考中动画 */
.thinking {
  display: flex;
  justify-content: center;
  padding: 20rpx;
}

.thinking-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #ff6b9d;
  margin: 0 8rpx;
  animation: thinking 1.4s infinite ease-in-out both;
}

.thinking-dot:nth-child(1) {
  animation-delay: -0.32s;
}

.thinking-dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes thinking {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

/* 快捷指令 */
.quick-commands {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  background-color: #fff;
}

.quick-btn {
  padding: 15rpx 30rpx;
  margin: 10rpx;
  background-color: #f0f0f0;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
}

/* 输入区 */
.input-area {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #fff;
  border-top: 1rpx solid #eee;
}

.text-input {
  flex: 1;
  height: 70rpx;
  padding: 0 30rpx;
  background-color: #f5f5f5;
  border-radius: 35rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 120rpx;
  height: 70rpx;
  line-height: 70rpx;
  margin-left: 20rpx;
  background-color: #ff6b9d;
  color: #fff;
  border-radius: 35rpx;
  font-size: 28rpx;
}

/* 语音按钮 */
.voice-btn {
  position: fixed;
  bottom: 200rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #ff6b9d, #ff9eb5);
  border-radius: 50%;
  box-shadow: 0 10rpx 30rpx rgba(255, 107, 157, 0.4);
}

.voice-btn.recording {
  background: linear-gradient(135deg, #ff4444, #ff6666);
}

.voice-icon {
  width: 60rpx;
  height: 60rpx;
}

.voice-btn text {
  color: #fff;
  font-size: 24rpx;
  margin-top: 10rpx;
}

/* 录音动画 */
.wave-animation {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  align-items: center;
  justify-content: center;
  width: 300rpx;
  height: 300rpx;
  background-color: rgba(255, 107, 157, 0.2);
  border-radius: 50%;
}

.wave {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: rgba(255, 107, 157, 0.3);
  animation: wave 2s infinite ease-out;
}

.wave2 {
  animation-delay: 0.5s;
}

.wave3 {
  animation-delay: 1s;
}

@keyframes wave {
  0% {
    transform: scale(0.5);
    opacity: 1;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}

/* 清除按钮 */
.clear-btn {
  position: fixed;
  top: 20rpx;
  right: 20rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  color: #999;
}
